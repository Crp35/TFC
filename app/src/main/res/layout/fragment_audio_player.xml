<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:padding="16dp">

    <!-- Portada del audio -->
    <ImageView
        android:id="@+id/imgCover"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:scaleType="centerCrop"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Título del audio -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/titulo_libro"
        android:textSize="20sp"
        android:textColor="@android:color/white"
        android:textStyle="bold"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/imgCover"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Tiempo actual / Tiempo total -->
    <LinearLayout
        android:id="@+id/tiempoLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvTiempoActual"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/tiempoInicial"
            android:textColor="@android:color/white"/>

        <TextView
            android:id="@+id/tvTiempoTotal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/tiempoInicial"
            android:textColor="@android:color/white"/>
    </LinearLayout>

    <!-- Barra de progreso -->
    <SeekBar
        android:id="@+id/seekBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:progress="0"
        android:thumbTint="#1DB954"
        android:progressTint="#1DB954"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintTop_toBottomOf="@id/tiempoLayout"
        app:layout_constraintBottom_toTopOf="@id/controlsLayout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Controles de reproducción -->
    <LinearLayout
        android:id="@+id/controlsLayout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- ATRÁS -->
        <ImageButton
            android:id="@+id/btnAtras"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:src="@drawable/ic_atras"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@android:color/white"
            android:scaleType="centerInside"/>

        <!-- PLAY / PAUSE -->
        <ImageButton
            android:id="@+id/btnPlayPause"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_marginHorizontal="32dp"
            android:src="@drawable/ic_play"
            android:tint="@android:color/white"
            android:scaleType="centerInside"/>

        <!-- STOP -->
        <ImageButton
            android:id="@+id/btnStop"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:src="@drawable/ic_stop"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@android:color/white"
            android:scaleType="centerInside"
            android:layout_marginEnd="16dp"/>

        <!-- ADELANTE -->
        <ImageButton
            android:id="@+id/btnAdelante"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:src="@drawable/ic_adelante"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@android:color/white"
            android:scaleType="centerInside"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
