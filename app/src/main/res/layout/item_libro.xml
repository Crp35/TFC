<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp">

    <!-- Portada -->
    <ImageView
        android:id="@+id/ivPortada"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:scaleType="fitXY"
        android:contentDescription="Portada del libro"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Estado (a la izquierda) -->
    <TextView
        android:id="@+id/tvEstado"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@android:color/white"
        android:padding="4dp"
        android:text="@string/estadoLibro"
        android:textSize="12sp"
        app:layout_constraintTop_toBottomOf="@id/ivPortada"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="8dp" />

    <!-- Tres puntos (a la derecha) -->
    <ImageView
        android:id="@+id/ivOpciones"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/ic_opciones_libros"
        app:tint="@android:color/white"
        android:clickable="true"
        android:focusable="true"
        android:padding="4dp"
        android:layout_marginEnd="8dp"
        app:layout_constraintTop_toBottomOf="@id/ivPortada"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>